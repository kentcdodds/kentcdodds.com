{
	// Temporary probe worker used to validate Worker Loader platform behavior
	// for the Cloudflare site migration. Safe to delete along with the
	// cf-loader-probe workflow once the migration architecture is settled.
	"name": "kcd-loader-probe-2309",
	"main": "index.mjs",
	"compatibility_date": "2026-03-17",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": true,
	"worker_loaders": [{ "binding": "LOADER" }]
}

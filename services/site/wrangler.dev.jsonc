{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "kentcdodds-com-dev",
	"main": "workers/dev-entry.ts",
	"compatibility_date": "2026-03-17",
	"compatibility_flags": [
		"nodejs_compat",
		"no_handle_cross_request_promise_resolution"
	],
	"workers_dev": true,
	"vars": {
		"NODE_ENV": "development",
		"MOCKS": "true",
		"OG_IMAGE_SECRET": "really_whatever_og"
	},
	"d1_databases": [
		{
			"binding": "APP_DB",
			"database_name": "kentcdodds-com-dev",
			"database_id": "local-dev-placeholder",
			"migrations_dir": "migrations"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SITE_CACHE_KV",
			"id": "local-dev-site-cache-kv"
		},
		{
			"binding": "CONTENT_KV",
			"id": "local-dev-content-kv"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA_BUCKET",
			"bucket_name": "kentcdodds-com-dev-media",
			"preview_bucket_name": "kentcdodds-com-dev-media"
		}
	],
	"images": {
		"binding": "IMAGES"
	},
	"assets": {
		"binding": "ASSETS",
		"directory": "./public"
	},
	"rules": [
		{
			"type": "Text",
			"globs": ["**/*.txt"]
		},
		{
			"type": "CompiledWasm",
			"globs": ["**/*.wasm"]
		},
		{
			"type": "Data",
			"globs": ["**/*.woff", "**/*.ttf"]
		}
	]
}

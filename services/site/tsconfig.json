{
	"include": [".react-router/types/**/*", "**/*.mdx", "**/*.ts", "**/*.tsx"],
	"extends": "../../tsconfig.base.json",
	"exclude": ["node_modules"],
	"compilerOptions": {
		"rootDirs": [".", "./.react-router/types"],
		"typeRoots": ["./types", "../../node_modules/@types"],
		"allowJs": true,
		"paths": {
			"#app/*": ["./app/*"],
			"#tests/*": ["./tests/*"]
		}
	},
	"mdx": {
		"checkMdx": true
	}
}

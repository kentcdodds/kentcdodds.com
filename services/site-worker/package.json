{
  "name": "site-worker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:site": "npm run build:router --workspace kentcdodds.com",
    "build:app-worker": "node ./scripts/build-app-worker.mjs",
    "build:worker": "npm run build:site && npm run build:app-worker",
    "format": "prettier --write .",
    "lint": "oxlint . --ignore-pattern .wrangler --ignore-pattern generated",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "wrangler deploy --config generated-wrangler.jsonc",
    "dev": "wrangler dev --config wrangler.jsonc --port 8792",
    "start": "npm run dev",
    "dry-run": "npm run build:worker && wrangler deploy --dry-run --config wrangler.jsonc",
    "d1:migrations:list:local": "wrangler d1 migrations list APP_DB --local --config ${WRANGLER_CONFIG:-wrangler.jsonc}",
    "d1:migrations:apply:local": "wrangler d1 migrations apply APP_DB --local --config ${WRANGLER_CONFIG:-wrangler.jsonc}",
    "d1:migrations:list:staging": "wrangler d1 migrations list APP_DB --remote --config ${WRANGLER_CONFIG:-generated-wrangler.jsonc}",
    "d1:migrations:apply:staging": "wrangler d1 migrations apply APP_DB --remote --config ${WRANGLER_CONFIG:-generated-wrangler.jsonc}",
    "d1:migrations:apply:production": "wrangler d1 migrations apply APP_DB --remote --config ${WRANGLER_CONFIG:-generated-wrangler.jsonc}",
    "provision:preview": "node ./scripts/provision-preview.mjs --target=staging",
    "provision:production": "node ./scripts/provision-preview.mjs --target=production",
    "secrets:generate": "node ./scripts/generate-worker-secrets.mjs",
    "publish:artifacts": "node ./scripts/publish-artifacts.mjs",
    "seed:preview-d1": "node ./scripts/seed-preview-d1.mjs",
    "test:local-e2e": "node ./scripts/local-e2e.mjs",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@epic-web/cachified": "^5.6.0",
    "@remix-run/data-table": "^0.3.0",
    "lru-cache": "^11.2.6",
    "bcryptjs": "^3.0.2",
    "react": "^19.2.4",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260306.1",
    "@epic-web/config": "^2.0.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.80.0"
  },
  "prettier": "@epic-web/config/prettier"
}

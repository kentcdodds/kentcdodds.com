{
  "name": "site-worker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:site": "npm run build:router --workspace kentcdodds.com",
    "format": "prettier --write .",
    "lint": "oxlint . --ignore-pattern .wrangler",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "npm run build:site && wrangler deploy",
    "dev": "npm run build:site && wrangler dev --port 8788",
    "start": "npm run dev",
    "dry-run": "npm run build:site && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "react-router": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260306.1",
    "@epic-web/config": "^2.0.0",
    "@types/node": "^25.5.0",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.80.0"
  },
  "prettier": "@epic-web/config/prettier"
}

{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "es2021",
		"lib": ["es2021"],
		"jsx": "react-jsx",
		"module": "es2022",
		"moduleResolution": "Bundler",
		"checkJs": false,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"types": ["./worker-configuration.d.ts"]
	},
	"include": ["worker-configuration.d.ts", "src/**/*.ts"]
}
